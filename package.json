{
  "name": "node-rest-api-cicd",
  "version": "1.0.0",
  "description": "Sample Node.js REST API with CI/CD pipeline and cloud deployment automation.",
  "private": true,
  "main": "dist/server.js",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/server.js",
    "test": "vitest run --coverage --pool=threads",
    "test:watch": "vitest",
    "lint": "tsc --noEmit --project tsconfig.json"
  },
  "dependencies": {
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.1",
    "@types/node": "^22.13.10",
    "@vitest/coverage-v8": "^3.1.1",
    "supertest": "^7.1.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.1.1"
  }
}
